{
  "name": "stack",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.30.1",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,mjs,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,mjs,json,md}\"",
    "clean": "turbo clean",
    "dev:cli": "turbo dev --filter=stackdev",
    "dev:web": "turbo dev --filter=@stack/web",
    "build:cli": "turbo build --filter=stackdev",
    "build:web": "turbo build --filter=@stack/web",
    "test:cli": "turbo test --filter=stackdev",
    "test:web": "turbo test --filter=@stack/web",
    "test:security": "turbo test:security --filter=stackdev",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "19.8.1",
    "@commitlint/config-conventional": "19.8.1",
    "@eslint/js": "9.39.4",
    "eslint": "9.39.4",
    "husky": "9.1.7",
    "lint-staged": "15.5.2",
    "prettier": "3.8.1",
    "turbo": "2.8.20",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.1"
  },
  "lint-staged": {
    "*.{ts,tsx,mjs}": [
      "eslint --no-warn-ignored --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
